# Firebase Storage Security Rules
# Copy these rules to Firebase Console > Storage > Rules

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload event posters
    match /event_posters/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload certificate templates
    match /certificate_templates/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // More permissive rules (use for testing only)
    // match /{allPaths=**} {
    //   allow read, write: if request.auth != null;
    // }
  }
}

